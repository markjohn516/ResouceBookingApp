@page "/bookings"
@using ResourceBooking.Core.DTOs
@using ResourceBooking.Blazor.Services
@inject IApiClient ApiClient

<PageTitle>My Bookings - Resource Booking</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1>All Bookings</h1>
            
            @if (isLoading)
            {
                <div class="alert alert-info">Loading bookings...</div>
            }
            else if (errorMessage != null)
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
            else if (bookings == null || bookings.Count == 0)
            {
                <div class="alert alert-warning">No bookings found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Resource</th>
                                <th>Employee</th>
                                <th>Start Time</th>
                                <th>End Time</th>
                                <th>Note</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in bookings)
                            {
                                <tr>
                                    <td>@booking.ResourceName</td>
                                    <td>@booking.EmployeeName</td>
                                    <td>@booking.StartTime.ToString("g")</td>
                                    <td>@booking.EndTime.ToString("g")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(booking.Note))
                                        {
                                            <small>@booking.Note</small>
                                        }
                                    </td>
                                    <td>@booking.CreatedAt.ToString("g")</td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteBooking(booking.Id)">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<BookingDto>? bookings;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            bookings = await ApiClient.GetBookingsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading bookings: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteBooking(int id)
    {
        try
        {
            await ApiClient.DeleteBookingAsync(id);
            bookings?.RemoveAll(b => b.Id == id);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting booking: {ex.Message}";
        }
    }
}
